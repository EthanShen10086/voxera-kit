#!/bin/sh

# post-commit：commit 落盘后 refresh Unreleased（git log 已含 HEAD），再 amend 并入同一 commit
if [ "$CHANGELOG_AMENDING" = "1" ]; then
  exit 0
fi

if [ "$CHANGELOG_SKIP" = "1" ]; then
  exit 0
fi

echo "Updating CHANGELOG.md (post-commit)..."
node scripts/changelog-append.mjs --refresh --mode=semver

if [ ! -f CHANGELOG.md ]; then
  exit 0
fi

if git diff --quiet CHANGELOG.md && git diff --cached --quiet CHANGELOG.md; then
  exit 0
fi

git add CHANGELOG.md
CHANGELOG_AMENDING=1 git commit --amend --no-edit --no-verify
echo "CHANGELOG.md amended into current commit."
