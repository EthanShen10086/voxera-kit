{
  "name": "@voxera-kit/faker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./lightweight": {
      "types": "./src/lightweight.ts",
      "import": "./src/lightweight.ts"
    },
    "./fakerjs": {
      "types": "./src/fakerjs.ts",
      "import": "./src/fakerjs.ts"
    }
  },
  "files": ["src", "dist"],
