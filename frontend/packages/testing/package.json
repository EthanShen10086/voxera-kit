{
  "name": "@voxera-kit/testing",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./vitest": {
      "types": "./src/vitest/index.ts",
      "import": "./src/vitest/index.ts"
    },
    "./msw": {
      "types": "./src/msw/index.ts",
      "import": "./src/msw/index.ts"
    },
    "./react": {
      "types": "./src/react/index.tsx",
      "import": "./src/react/index.tsx"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@voxera-kit/di": "workspace:*",
    "@voxera-kit/fixture": "workspace:*",
    "@voxera-kit/i18n": "workspace:*",
    "@voxera-kit/theme": "workspace:*",
    "msw": "^2.7.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vitest": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@voxera-kit/config": "workspace:*",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
